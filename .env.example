# StyleCraft configuration — NO API KEY REQUIRED.
# Auth to Vertex AI is via Application Default Credentials (ADC): the runtime
# service account (Cloud Run) or your local `gcloud auth application-default login`.

# ── Run without any cloud at all ──────────────────────────────────────────────
# Set to 1 to use the deterministic mock Writer + Coach (no GCP, no key).
# The whole UI works in this mode; scores are clearly labelled "simulated".
STYLECRAFT_MOCK=0

# ── Vertex AI (only needed when STYLECRAFT_MOCK=0) ────────────────────────────
# GCP project that hosts Vertex AI. On app.gyatso.me this is inferred from ADC.
GCP_PROJECT=
VERTEX_LOCATION=us-central1

# Weak Writer / strong Coach.
WRITER_MODEL=gemini-2.5-flash-lite
COACH_MODEL=gemini-2.5-pro

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005
# API mount path — matches the production nginx prefix.
STYLECRAFT_API_BASE=/stylecraft/api

# ── Web build ─────────────────────────────────────────────────────────────────
# Set to /stylecraft/ for the app.gyatso.me sub-app build; leave unset for standalone.
# VITE_BASE=/stylecraft/
